# ============================================
# Trading Bot Configuration Template
# ============================================
# Copy this file to .env and fill in your credentials

# Bybit API Configuration
# Get your API keys from: https://www.bybit.com/app/user/api-management
# NOTE: Use mainnet API keys (not testnet)
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Telegram Bot Configuration
# 1. Create bot: Talk to @BotFather on Telegram, use /newbot command
# 2. Get bot token from BotFather
# 3. Get your chat ID: Talk to @userinfobot on Telegram
# 4. Multiple chat IDs: Separate with commas (no spaces)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_IDS=123456789,987654321

# Database Configuration (TimescaleDB)
# Change password for production use
POSTGRES_USER=trading_bot
POSTGRES_PASSWORD=secure_password_123
POSTGRES_DB=trading_db
DATABASE_URL=postgresql://trading_bot:secure_password_123@timescaledb:5432/trading_db

# Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO

# Paper Trading Settings
# Set to true for paper trading (simulated trades)
# Set to false for live trading (real money - NOT RECOMMENDED)
PAPER_TRADING=true
INITIAL_BALANCE=100

# ============================================
# How to get Bybit API Keys:
# ============================================
# 1. Go to https://www.bybit.com/app/user/api-management
# 2. Click "Create New Key"
# 3. Select "System-generated API Keys"
# 4. Set permissions:
#    - Read-Write (for paper trading)
#    - Read-Only (for live monitoring)
# 5. Copy API Key and Secret
# 6. Paste them above
#
# IMPORTANT: 
# - Never share your API keys
# - Use IP whitelist for security
# - This bot uses MAINNET (real market data)
# - Paper trading = simulated trades only

# ============================================
# How to get Telegram Bot Token:
# ============================================
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot command
# 3. Follow instructions to create bot
# 4. Copy the token (format: 1234567890:ABCdef...)
# 5. Paste it above
#
# How to get Chat ID:
# 1. Open Telegram and search for @userinfobot
# 2. Send /start command
# 3. Copy your ID (format: 123456789)
# 4. Paste it above
#
# Multiple users:
# - Add multiple chat IDs separated by commas
# - Example: 123456789,987654321,555555555
